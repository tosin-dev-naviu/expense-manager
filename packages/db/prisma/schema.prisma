generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  tenant_admin
  manager
  employee
}

enum ExpenseStatus {
  draft
  pending
  approved
  rejected
}

enum ExtractionStatus {
  pending
  processing
  completed
  failed
}

model User {
  id                String       @id @default(cuid())
  name              String?
  email             String?      @unique
  emailVerified     DateTime?
  passwordHash      String?
  image             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  accounts          Account[]
  sessions          Session[]
  memberships       Membership[]
  invitesSent       Invite[]     @relation("InviteCreatedBy")
  receiptUploads    ReceiptUpload[]
  createdExpenses   Expense[]    @relation("ExpenseCreatedBy")
  submittedExpenses Expense[]    @relation("ExpenseSubmittedBy")
  decidedExpenses   Expense[]    @relation("ExpenseDecidedBy")
}

model Tenant {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  memberships    Membership[]
  invites        Invite[]
  teams          Team[]
  budgets        Budget[]
  receiptUploads ReceiptUpload[]
  expenses       Expense[]
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  teamId    String?
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([teamId])
}

model Invite {
  id              String   @id @default(cuid())
  tenantId        String
  email           String
  role            Role
  token           String   @unique
  status          String
  expiresAt       DateTime
  teamId          String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdByUser   User?    @relation("InviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, email])
  @@index([teamId])
}

model Team {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  invites        Invite[]
  budgets        Budget[]
  receiptUploads ReceiptUpload[]
  expenses       Expense[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Budget {
  id        String   @id @default(cuid())
  tenantId  String
  teamId    String
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@index([tenantId, teamId])
}

model ReceiptUpload {
  id               String           @id @default(cuid())
  tenantId         String
  uploadedByUserId String
  teamId           String?
  objectKey        String
  fileName         String
  mimeType         String
  extractionStatus ExtractionStatus @default(pending)
  extractionError  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedByUser   User             @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  team             Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  expenses         Expense[]

  @@index([tenantId, extractionStatus])
  @@index([uploadedByUserId])
  @@index([teamId])
}

model Expense {
  id                String        @id @default(cuid())
  tenantId          String
  teamId            String
  budgetId          String?
  receiptUploadId   String?
  createdByUserId   String
  submittedByUserId String?
  decidedByUserId   String?
  submitterName     String?
  submitterEmail    String?
  merchantName      String?
  description       String?
  amount            Decimal?      @db.Decimal(12, 2)
  expenseDate       DateTime?
  status            ExpenseStatus @default(draft)
  submittedAt       DateTime?
  decidedAt         DateTime?
  decisionNote      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team              Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  budget            Budget?       @relation(fields: [budgetId], references: [id], onDelete: SetNull)
  receiptUpload     ReceiptUpload? @relation(fields: [receiptUploadId], references: [id], onDelete: SetNull)
  createdByUser     User          @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  submittedByUser   User?         @relation("ExpenseSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  decidedByUser     User?         @relation("ExpenseDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([teamId, status])
  @@index([budgetId])
  @@index([receiptUploadId])
  @@index([createdByUserId])
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
